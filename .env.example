# Copier ce fichier en .env et remplir les valeurs
# Générer des secrets : openssl rand -hex 32
# Ne jamais committer le vrai .env

# ── IA ─────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=          # https://aistudio.google.com/

# ── Sécurité ───────────────────────────────────────────────────────────────────
ADMIN_KEY=               # min 16 chars — openssl rand -base64 16
JWT_SECRET_KEY=          # min 32 chars — openssl rand -hex 32

# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./database.db   # prod → postgresql+asyncpg://...

# ── Paiement (futur) ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=       # sk_live_... (https://dashboard.stripe.com)
STRIPE_WEBHOOK_SECRET=   # whsec_... (webhook Stripe → /payments/webhook)
STRIPE_PREMIUM_PRICE_ID= # price_... (ID produit Premium dans Stripe)

# ── Push notifications (futur) ────────────────────────────────────────────────
FCM_SERVER_KEY=          # Firebase Cloud Messaging server key

# ── Stockage images (futur) ───────────────────────────────────────────────────
R2_ACCOUNT_ID=           # Cloudflare R2 (ou S3_BUCKET_NAME pour AWS)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=digital-stylist-uploads
R2_PUBLIC_URL=           # https://pub-xxx.r2.dev

# ── Logs ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
